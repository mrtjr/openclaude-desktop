{
  "name": "openclaude-desktop",
  "version": "2.7.0",
  "description": "Desktop GUI for OpenClaude",
  "author": "OpenClaude",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "electron": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.openclaude.desktop",
    "productName": "OpenClaude Desktop",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/katex": "^0.16.7",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^4.1.4",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.0.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.4",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@supabase/supabase-js": "^2.103.3",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.1.0",
    "highlight.js": "^11.10.0",
    "katex": "^0.16.11",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.8.0",
    "marked": "^14.1.0",
    "marked-katex-extension": "^5.1.7",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tiktoken": "^1.0.21"
  }
}
